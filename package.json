{
  "name": "captcha",
  "type": "module",
  "workspaces": [
    "www"
  ],
  "scripts": {
    "build": "bun --bun dressed build",
    "checks": "tsc --noEmit && biome check --write",
    "dev": "bun run build && bun start",
    "dist": "bun run build && bun build src/connection.ts --target=bun --outfile=bundle.js --packages=external --production",
    "register": "bun run build -r && bun start",
    "start": "bun src/connection.ts"
  },
  "dependencies": {
    "@dressed/react": "^2.0.0",
    "@dressed/ws": "^0.5.0",
    "@libsql/client": "^0.17.4",
    "@nanostores/react": "^1.1.0",
    "@tanstack/react-query": "^5.101.4",
    "dressed": "^2.0.0",
    "drizzle-orm": "^0.45.2",
    "emojibase-data": "^17.0.0",
    "fast-shuffle": "^6.2.1",
    "nanostores": "^1.4.1",
    "react": "^19.2.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@dressed/framework": "^0.6.0",
    "@types/bun": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "typescript": "^7.0.2"
  }
}
